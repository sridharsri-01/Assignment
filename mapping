import java.util.*;
public class MapAssignment {
    public static void main(String[] args) {
        Map<String, Integer> map = new HashMap<>();
        map.put("Maths", 90);
        map.put("Science", 85);
        map.put("English", 88);
        for(Map.Entry<String, Integer> m : map.entrySet()) {
            System.out.println(m.getKey() + " : " + m.getValue());
        }
    }
}

